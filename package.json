{
    "name":  "credara-contracts",
    "version":  "1.0.0",
    "description":  "Privacy-aware credential proof registry contracts for Credara Labs.",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "compile":  "hardhat compile",
                    "test":  "hardhat test",
                    "node":  "hardhat node",
                    "deploy:local":  "hardhat run scripts/deploy.ts --network localhost",
                    "typecheck":  "hardhat compile \u0026\u0026 tsc --noEmit",
                    "lint":  "hardhat compile \u0026\u0026 tsc --noEmit"
                },
    "keywords":  [
                     "solidity",
                     "hardhat",
                     "credentials",
                     "certificates",
                     "verification",
                     "privacy"
                 ],
    "author":  "Credara Labs",
    "license":  "MIT",
    "devDependencies":  {
                            "@nomicfoundation/hardhat-ethers":  "^4.0.14",
                            "@nomicfoundation/hardhat-network-helpers":  "^3.0.11",
                            "@nomicfoundation/hardhat-toolbox-mocha-ethers":  "^3.0.7",
                            "@types/mocha":  "^10.0.10",
                            "@types/node":  "^26.1.1",
                            "chai":  "^6.2.2",
                            "ethers":  "^6.17.0",
                            "hardhat":  "^3.9.1",
                            "mocha":  "^11.7.6",
                            "ts-node":  "^10.9.2",
                            "typescript":  "^6.0.3"
                        }
}
